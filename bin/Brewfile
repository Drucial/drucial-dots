# Base manifest: taps, fonts, and tooling not owned by a single config.
# Per-config dependencies live in configs/<tool>/Brewfile. bin/sync concatenates
# this file with all of those and pipes the result to `brew bundle`.

# Taps — only those a kept tool needs.
tap "dlvhdr/formulae"      # diffnav, gh-dash
tap "felixkratz/formulae"  # yabai

