brew "bat"
brew "zoxide"
brew "lsd"
brew "starship"            # prompt; config: configs/starship.toml

# Configless daily-driver tooling.
brew "gh"
brew "jq"
brew "yq"
brew "git-filter-repo"
brew "tldr"
brew "tree"

# Language / runtime toolchains.
brew "go"
brew "node"
brew "pnpm"
brew "rbenv"
brew "python@3.13"
brew "lua"
brew "cmake"

# Fonts.
cask "font-jetbrains-mono"
cask "font-jetbrains-mono-nerd-font"
cask "font-hack-nerd-font"
cask "font-symbols-only-nerd-font"
cask "sf-symbols"

# GUI / other.
cask "1password-cli"

